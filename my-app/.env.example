# ========================
# VAYU Backend — .env file
# Copy this to .env and fill in your real values
# NEVER commit .env to git!
# ========================

PORT=8000

# --- Google Cloud ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# --- Gemini API ---
GEMINI_API_KEY=your-gemini-api-key-here

# --- BigQuery ---
BIGQUERY_DATASET=vayu

# --- Firebase Admin SDK ---
# Path to your downloaded Firebase service account JSON key
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# --- Twilio (for SMS alerts) ---
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# --- Sumit's ML Model (fill when ready) ---
# SUMIT_MODEL_URL=https://your-vertex-ai-endpoint.run.app/predict

# Ankit
NEXT_PUBLIC_GOOGLE_MAP_API_KEY=YOUR_API_KEY

# --- Misc ---
NODE_ENV=development
